# AI Fabrix Documentation Environment Configuration
# Copy this file to .env and modify as needed

# Jekyll Configuration
JEKYLL_BASEURL=/aifabrix-docs
JEKYLL_URL=https://docs-dev.aifabrix.ai

# Custom Domain (optional)
# If you have a custom domain, set this instead of JEKYLL_URL
# CUSTOM_DOMAIN=https://docs.aifabrix.ai

# Development vs Production
NODE_ENV=development

# Document360 Sync (aifabrix-d360) — optional; uncomment and set to enable sync
# One API token can target two project versions (lanes): user docs vs API reference.
# DOCUMENT360_API_TOKEN=your-api-token-here
# DOCUMENT360_PROJECT_ID=your-project-id-here
# DOCUMENT360_BASE_URL=https://apihub.document360.io

# Project version UUIDs from GET /v2/ProjectVersions (when you have separate main/public versions)
# DOCUMENT360_PROJECT_VERSION_ID_DOCS=
# DOCUMENT360_PROJECT_VERSION_ID_API_DOCS=

# Optional: if UUIDs are omitted, match slug / version_code_name from the API
# DOCUMENT360_VERSION_SLUG_DOCS=
# DOCUMENT360_VERSION_SLUG_API_DOCS=

# When not using CLI args, SYNC_TARGET=api-docs selects the API-docs lane (default is docs)
# SYNC_TARGET=api-docs

# Local roots: user docs ./docs (default; Jekyll + sync-document360). API reference ./api-docs
# (npm run sync-document360:api-docs sets SYNC_SOURCE_PATH=./api-docs for that run).
# SYNC_SOURCE_PATH=./docs

# SQLite: omit DATABASE_PATH for per-target defaults under ./data/:
#   ./data/sync-docs.db (docs) | ./data/sync-api-docs.db (api-docs)
# DATABASE_PATH=

# MOCK_MODE=true  # smoke test without real Document360 API calls
# SYNC_DRY_RUN=true
# LOG_LEVEL=info
